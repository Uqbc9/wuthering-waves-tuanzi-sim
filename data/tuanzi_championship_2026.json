  "racers": [
    {
      "id": "lu_hesi",
      "name": "陆·赫斯",
      "group": "A",
      "skill": {
        "name": "来颗糖吧",
        "description": "当触发推进装置时，可额外前进3格。但触发阻遏装置时，将额外后退1格。",
        "type": "tile_affinity",
        "boost_extra_steps": 3,
        "hindrance_extra_steps": -1
      }
    },
    {
      "id": "siglica",
      "name": "西格莉卡",
      "group": "A",
      "skill": {
        "name": "日灵，帮帮忙！",
        "description": "每轮投骰子后，标记排名紧邻自身且更高的至多两个团子。被标记团子在本回合中少前进1格，但移动距离不会降到0或更少。",
        "type": "mark_higher_neighbors_round_start",
        "count": 2,
        "step_delta": -1,
        "minimum_move": 1
      }
    },
    {
      "id": "denia",
      "name": "达妮娅",
      "group": "A",
      "skill": {
        "name": "好事成“双”",
        "description": "投骰子时，若投出和上一次相同的点数，则额外前进2格。",
        "type": "same_roll_bonus",
        "bonus_steps": 2,
        "initial_order_roll_counts": false
      }
    },
    {
      "id": "hiyuki",
      "name": "绯雪",
      "group": "A",
      "skill": {
        "name": "引路白鸟",
        "description": "当该团子与布大王相遇后，之后每次移动时都将额外前进1格。",
        "type": "after_meeting_budawang_bonus",
        "bonus_steps": 1
      }
    },
    {
      "id": "cartethyia",
      "name": "卡提希娅",
      "group": "A",
      "skill": {
        "name": "翻盘桥段",
        "description": "每场比赛最多触发1次。自身移动结束后，若处于最后一名，本场比赛剩余回合都会有60%概率额外前进2格。",
        "type": "last_place_comeback",
        "trigger_once": true,
        "future_bonus_probability": 0.6,
        "bonus_steps": 2
      }
    },
    {
      "id": "phoebe",
      "name": "菲比",
      "group": "A",
      "skill": {
        "name": "岁主庇佑",
        "description": "50%概率额外前进1格。",
        "type": "per_move_chance_bonus",
        "probability": 0.5,
        "bonus_steps": 1
      }
    },
    {
      "id": "chisaki",
      "name": "千咲",
      "group": "B",
      "skill": {
        "name": "视阈解眀",
        "description": "投骰子时，若投出的结果为本轮所有点数最小之一，则额外前进2格。",
        "type": "round_min_roll_bonus",
        "bonus_steps": 2
      }
    },
    {
      "id": "morning",
      "name": "莫宁",
      "group": "B",
      "skill": {
        "name": "精密演算",
        "description": "投骰子时，点数将固定在3/2/1循环出现。",
        "type": "fixed_roll_cycle",
        "sequence": [3, 2, 1]
      }
    },
    {
      "id": "linnae",
      "name": "琳奈",
      "group": "B",
      "skill": {
        "name": "炫彩时刻！",
        "description": "每回合中，有60%概率按照双倍点数移动，但有20%概率当回合无法移动。",
        "type": "chance_double_or_skip",
        "double_probability": 0.6,
        "skip_probability": 0.2
      }
    },
    {
      "id": "aemis",
      "name": "爱弥斯",
      "group": "B",
      "skill": {
        "name": "电子幽灵登场",
        "description": "每场比赛一次，轮到自己行动并走完格子后，若位于15格以上且前方存在其他非布大王的团子，则会传送到前方最近团子顶端；本格团子不计入前方目标，被别人带动或前方无人时不会触发。",
        "type": "midpoint_nearest_ahead_teleport_once",
        "trigger_once": true,
        "trigger_position": 15
      }
    },
    {
      "id": "shorekeeper",
      "name": "守岸人",
      "group": "B",
      "skill": {
        "name": "收束的未来",
        "description": "骰子只会掷出2或3。",
        "type": "restricted_roll",
        "sides": [2, 3]
      }
    },
    {
      "id": "carllotta",
      "name": "珂莱塔",
      "group": "B",
      "skill": {
        "name": "利润加倍",
        "description": "28%概率以骰子的双倍点数前进。",
        "type": "chance_double_roll",
        "probability": 0.28
      }
    },
    {
      "id": "augusta",
      "name": "奥古斯塔",
      "group": "C",
      "skill": {
        "description": "回合开始时，若该团子处于堆叠最顶端，则在本回合不行动，且在下回合中最后一个行动。",
        "type": "top_skip_next_round_last"
      }
    },
    {
      "id": "younuo",
      "name": "尤诺",
      "group": "C",
      "skill": {
        "description": "每场比赛一次，当该团子经过赛程中点后，若该团子排名前后有其他非布大王团子，则将这些团子传送至自己的格子。这些团子的堆叠顺序将与传送前的排名顺序一致。",
        "type": "midpoint_adjacent_rank_teleport_once",
        "trigger_once": true,
        "trigger_position": 16
      }
    },
    {
      "id": "florof",
      "name": "弗洛洛",
      "group": "C",
      "skill": {
        "description": "回合开始时，若该团子处于堆叠最底层，则在移动时额外前进3格。",
        "type": "round_start_bottom_bonus",
        "bonus_steps": 3
      }
    },
    {
      "id": "changli",
      "name": "长离",
      "group": "C",
      "skill": {
        "description": "如果下方堆叠其他团子，下一个回合有65%的概率最后一个行动。",

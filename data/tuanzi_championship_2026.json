    },
    {
      "id": "jinhsi",
      "name": "今汐",
      "group": "C",
      "skill": {
        "description": "如果头顶堆叠其他团子，有40%的概率移动到所有团子的最上方。",
        "type": "above_stack_chance_to_top",
        "probability": 0.4
